<%= form_with url: registrations_path,
              scope: :registration,
              method: :post,
              local: true,
              html: { class: "form form--registration" } do |f| %>

  <header class="form__header">
    <h1 class="form__title">Create account</h1>
    <p class="form__hint">Use your email address to join your neighbourhood.</p>
  </header>

  <div class="form__body">
    <div class="field field--text">
      <%= f.label :email, "Email", class: "field__label" %>
      <%= f.email_field :email,
                        autocomplete: "email",
                        inputmode: "email",
                        required: true,
                        class: "field__input" %>
    </div>

    <div class="field field--text">
      <%= f.label :name, "Name", class: "field__label" %>
      <%= f.text_field :name,
                       autocomplete: "name",
                       required: true,
                       class: "field__input" %>
    </div>

    <div class="field field--password">
      <%= f.label :password, "Password", class: "field__label" %>
      <%= f.password_field :password,
                           autocomplete: "new-password",
                           required: true,
                           class: "field__input" %>
      <p class="field__help">Use at least 12 characters.</p>
    </div>

    <div class="field field--password">
      <%= f.label :password_confirmation, "Password", class: "field__label" %>
      <%= f.password_field :password_confirmation,
                           autocomplete: "new-password",
                           required: true,
                           class: "field__input" %>
    </div>
  </div>

  <footer class="form__footer">
    <%= f.submit "Create account", class: "button button--primary" %>
    <%= link_to "Already have an account? Sign in", new_identity_session_path, class: "link" %>
  </footer>
<% end %>

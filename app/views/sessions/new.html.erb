<%# app/views/sessions/new.html.erb %>

<%= form_with url: session_path,
              scope: :session,
              method: :post,
              local: true,
              html: { class: "form form--session" } do |f| %>

  <header class="form__header">
    <h1 class="form__title">Sign in</h1>
    <p class="form__hint">Use the email address you registered with.</p>
  </header>

  <div class="form__body">
    <div class="field field--text">
      <%= f.label :email, "Email", class: "field__label" %>
      <%= f.email_field :email,
                        value: params.dig(:session, :email),
                        autocomplete: "email",
                        inputmode: "email",
                        required: true,
                        class: "field__input" %>
    </div>

    <div class="field field--password">
      <%= f.label :password, "Password", class: "field__label" %>
      <%= f.password_field :password,
                           autocomplete: "current-password",
                           required: true,
                           class: "field__input" %>
    </div>
  </div>

  <footer class="form__footer">
    <%= f.submit "Sign in", class: "button button--primary" %>
    <%= link_to "Forgot your password?", new_password_reset_path, class: "link" %>
    <%= link_to "Create an account", new_registration_path, class: "link" %>
  </footer>
<% end %>
